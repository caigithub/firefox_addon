{
	"description": "chat-outline adds a thin outline to the current ai chat message.",
	"manifest_version": 3,
	"name": "Chat Outline",
	"version": "1.1",
	"homepage_url": "https://github.com/caigithub/firefox_addon/tree/master/chat_outline",
	"author": "i_am_cai@163.com",
	"icons": {
		"48": "icons/border-48.png"
	},

	"browser_specific_settings": {
		"gecko": {
			"id": "chat-outline@i_am_cai",
			"data_collection_permissions": {
				"required": ["none"]
			}
		}
	},

	"content_scripts": [
		{
			"matches": ["*://*.kimi.com/*"],
			"js": ["main.js"]
		}
	]
}
